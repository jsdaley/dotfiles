{
  "workbench.colorTheme": "Monokai",
  "atomKeymap.promptV3Features": true,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.formatOnPaste": false,
  "editor.tabSize": 2,
  "projectManager.vscode.baseFolders": [
    "$home/workspace"
  ],
  "projectManager.git.baseFolders": [
    "$home/workspace"
  ],
  "projectManager.openInNewWindowWhenClickingInStatusBar": true,
  "window.newWindowDimensions": "maximized",
  "workbench.startupEditor": "none",
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/coverage": true,
    "**/node_modules": true
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "html.validate.styles": false,
  "html.validate.scripts": false,
  "window.zoomLevel": -1,
  "workbench.activityBar.location": "hidden",
  "pascal.formatter.engine": "ptop",
  "pascal.formatter.enginePath": "/usr/local/bin/ptop",
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.scrollback": 100000,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.macOptionIsMeta": true,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.minimumContrastRatio": 1,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "editor.unicodeHighlight.nonBasicASCII": false,
  "//dev": "Salvaged from the work machine — general dev + per-language settings (inert where the language/tool isn't used).",
  "editor.renderWhitespace": "all",
  "editor.renderControlCharacters": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.surveys.enabled": false,
  "typescript.tsserver.log": "off",
  "python.languageServer": "Pylance",
  "black-formatter.args": [
    "--experimental-string-processing"
  ],
  "docker.extension.enableComposeLanguageServer": false,
  "nxConsole.showNodeVersionOnStartup": false,
  "powershell.powerShellDefaultVersion": "pwsh",
  "powershell.powerShellAdditionalExePaths": {
    "pwsh": "/opt/homebrew/bin/pwsh"
  },
  "terminal.external.osxExec": "Ghostty.app",
  "[json]": { "editor.defaultFormatter": "vscode.json-language-features" },
  "[jsonc]": { "editor.defaultFormatter": "vscode.json-language-features" },
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[python]": { "editor.formatOnType": true },
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": { "other": true, "comments": false, "strings": true },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": { "editor.defaultFormatter": "redhat.vscode-yaml" },
  "claudeCode.preferredLocation": "panel",
  "//": "Terminal panel colors mirror the iTerm2/Ghostty palette (terminal-only; editor keeps its theme). Drop terminal.background/foreground to blend with the editor theme instead.",
  "workbench.colorCustomizations": {
    "terminal.background": "#0d0f18",
    "terminal.foreground": "#fffaf3",
    "terminal.selectionBackground": "#002a3a",
    "terminalCursor.foreground": "#ff0017",
    "terminalCursor.background": "#0d0f18",
    "terminal.ansiBlack": "#222222",
    "terminal.ansiRed": "#ff000f",
    "terminal.ansiGreen": "#8ce00a",
    "terminal.ansiYellow": "#ffb900",
    "terminal.ansiBlue": "#008df8",
    "terminal.ansiMagenta": "#6c43a5",
    "terminal.ansiCyan": "#00d7eb",
    "terminal.ansiWhite": "#ffffff",
    "terminal.ansiBrightBlack": "#444444",
    "terminal.ansiBrightRed": "#ff273f",
    "terminal.ansiBrightGreen": "#abe05a",
    "terminal.ansiBrightYellow": "#ffd141",
    "terminal.ansiBrightBlue": "#0092ff",
    "terminal.ansiBrightMagenta": "#9a5feb",
    "terminal.ansiBrightCyan": "#67ffef",
    "terminal.ansiBrightWhite": "#ffffff"
  }
}
